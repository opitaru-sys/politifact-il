generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local dev only. Mirrors schema.prisma but uses SQLite for zero-setup
  // local work. Regenerate the client against this schema with
  // `npm run db:gen:local`. KEEP IN SYNC with schema.prisma — same models,
  // fields, indices. Production deploy uses schema.prisma (Postgres).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Politician {
  id        String   @id @default(cuid())
  name      String
  party     String
  role      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  claims    Claim[]
}

model Claim {
  id             String   @id @default(cuid())
  politicianId   String
  politician     Politician @relation(fields: [politicianId], references: [id])
  quote          String
  verdict        String   // "true" | "half-true" | "false"
  summary        String?  // one-sentence TL;DR of the explanation
  explanation    String
  source         String   // where the politician said it (e.g. "Ynet")
  sourceUrl      String
  factSource     String?  // authoritative data source
  factSourceUrl  String?
  topic          String
  date           DateTime
  status         String   @default("published") // "draft" | "review" | "published"
  confidence     Float?   // AI confidence score 0-1
  editorApproved Boolean  @default(false) // passed second-pass AI verification
  verifiedAt     DateTime? // when the second-pass verifier ran
  verifierNotes  String?  // issues raised by the verifier (if not approved)
  telegramPostedAt DateTime? // when auto-posted to the Telegram channel; null = not yet
  humanDecision    String?   // "dismiss" | "publish" — editor's call in /admin/review
  humanDecisionAt  DateTime? // when the editor made that call
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reports        Report[]
  comments       Comment[]

  @@index([politicianId])
  @@index([date])
  @@index([verdict])
}

model Comment {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
  author    String   // free-text name; no auth yet
  body      String
  createdAt DateTime @default(now())

  @@index([claimId])
  @@index([createdAt])
}

model Report {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
  reason    String
  details   String?
  createdAt DateTime @default(now())

  @@index([claimId])
}

model Article {
  id            String   @id @default(cuid())
  title         String
  url           String   @unique
  source        String   // "ynet" | "n12" | "walla" | etc
  content       String?
  publishedAt   DateTime?
  fetchedAt     DateTime @default(now())
  processed     Boolean  @default(false)
  extractedData String?  // JSON: extracted quotes and claims

  @@index([source])
  @@index([processed])
}
