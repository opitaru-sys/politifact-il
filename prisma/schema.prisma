generator client {
  provider      = "prisma-client-js"
  // Vercel's serverless runtime needs the RHEL OpenSSL 3 binary in addition
  // to the build host's native binary. Without this, runtime functions crash
  // with "PrismaClientInitializationError: Unable to require libquery_engine".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  // Production target: Neon Postgres. Local dev uses the same Neon dev branch
  // or a local docker `postgres:16` instance (see DEPLOY.md). The schema is
  // designed to be portable; see scripts/migrate-to-postgres.mts for the
  // one-time SQLite→Postgres data migration.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Politician {
  id        String   @id @default(cuid())
  name      String
  party     String
  role      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  claims    Claim[]
  knessetActivity KnessetActivity?
}

/// Knesset activity snapshot for one MK. One row per Politician, refreshed
/// daily by scripts/ingest-knesset-activity.mts. The metrics are computed
/// over a rolling window (default 90 days) and used by the
/// `<KnessetActivityCard>` on /politician/[id] + the leaderboard's
/// attendance threshold filter.
///
/// Data sources:
///  - Knesset OData `ParliamentInfo.svc` for bills (`KNS_Bill` +
///    `KNS_BillInitiator`, fresh — last bill ~4 days old) and committee
///    memberships (`KNS_PersonToPosition`).
///  - Our own `Article` table for plenum participation (counting
///    distinct sessions where the MK spoke). Knesset's public vote
///    OData is 5+ years stale and unusable for this purpose.
model KnessetActivity {
  id                       String     @id @default(cuid())
  politicianId             String     @unique
  politician               Politician @relation(fields: [politicianId], references: [id])

  /// KNS_Person.PersonID — kept so re-queries don't have to redo
  /// the Hebrew-name → MK lookup every run.
  knsPersonId              Int

  /// Window the stats below cover. Stored explicitly so a future cron
  /// can recompute over a different window without ambiguity.
  windowStart              DateTime
  windowEnd                DateTime

  /// Active plenum participation — derived from our Article rows
  /// (source="כנסת · מליאה"). We count distinct plenum sessions in
  /// the window where the MK spoke. Stronger signal than passive
  /// attendance — silence in the room doesn't show here. Knesset's
  /// own vote-attendance OData is 5+ years stale so this is the
  /// best public signal available.
  plenumSessionsTotal      Int
  plenumSessionsSpoken     Int
  plenumParticipationPct   Float

  /// Bills the MK initiated or co-initiated whose PublicationDate
  /// falls in the window.
  billsSponsored           Int

  /// Snapshot of current committee / role positions. JSON array of
  /// `{ id: number, name: string }`. Not windowed.
  committeesMember         Json

  fetchedAt                DateTime   @default(now())

  @@index([politicianId])
}

model Claim {
  id             String   @id @default(cuid())
  politicianId   String
  politician     Politician @relation(fields: [politicianId], references: [id])
  quote          String
  verdict        String   // "true" | "half-true" | "false"
  summary        String?  // one-sentence TL;DR of the explanation
  explanation    String
  source         String   // where the politician said it (e.g. "Ynet")
  sourceUrl      String
  factSource     String?  // authoritative data source
  factSourceUrl  String?
  topic          String
  date           DateTime
  status         String   @default("published") // "draft" | "review" | "published"
  confidence     Float?   // AI confidence score 0-1
  editorApproved Boolean  @default(false) // passed second-pass AI verification
  verifiedAt     DateTime? // when the second-pass verifier ran
  verifierNotes  String?  // issues raised by the verifier (if not approved)
  /// Set when a previously-public claim is amended or removed.
  /// Drives the /corrections log. Free-text Hebrew reason like
  /// "הוסר: דיווח עיתונאי בגוף שלישי, לא אמירה של הפוליטיקאי".
  correctionNote String?
  /// When the correction happened. Null = no correction. Updated
  /// independently of `updatedAt` (which updates on every edit).
  correctedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reports        Report[]
  comments       Comment[]

  @@index([politicianId])
  @@index([date])
  @@index([verdict])
}

model Comment {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
  author    String   // free-text name; no auth yet
  body      String
  createdAt DateTime @default(now())

  @@index([claimId])
  @@index([createdAt])
}

model Report {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
  reason    String
  details   String?
  createdAt DateTime @default(now())

  @@index([claimId])
}

model Article {
  id            String   @id @default(cuid())
  title         String
  url           String   @unique
  source        String   // "ynet" | "n12" | "walla" | etc
  content       String?
  publishedAt   DateTime?
  fetchedAt     DateTime @default(now())
  processed     Boolean  @default(false)
  extractedData String?  // JSON: extracted quotes and claims

  @@index([source])
  @@index([processed])
}

/// One row per day. Written at the end of each daily cron run and
/// surfaced on the admin status page so we can spot regressions
/// (queue depth blowing up, approval rate dropping, no fresh claims
/// for N days). Day field is stored as a string in YYYY-MM-DD form
/// so we get one row per calendar day regardless of write time.
model DailySnapshot {
  id              String   @id @default(cuid())
  day             String   @unique   // "2026-05-23"
  totalClaims     Int
  publishedClaims Int
  editorApproved  Int
  queueDepth      Int
  totalArticles   Int
  lastClaimAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([day])
}
