generator client {
  provider      = "prisma-client-js"
  // Vercel's serverless runtime needs the RHEL OpenSSL 3 binary in addition
  // to the build host's native binary. Without this, runtime functions crash
  // with "PrismaClientInitializationError: Unable to require libquery_engine".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  // Production target: Neon Postgres. Local dev uses the same Neon dev branch
  // or a local docker `postgres:16` instance (see DEPLOY.md). The schema is
  // designed to be portable; see scripts/migrate-to-postgres.mts for the
  // one-time SQLite→Postgres data migration.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Politician {
  id        String   @id @default(cuid())
  name      String
  party     String
  role      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  claims    Claim[]
  knessetActivity KnessetActivity?
  credibilitySnapshots CredibilitySnapshot[]
}

/// Snapshot of a politician's credibility computed over a rolling window
/// ending at `asOf`. Rebuilt nightly by scripts/snapshot-credibility.mts
/// (wired into scripts/daily.mts) and backfilled by
/// scripts/backfill-cred-snapshots.mts for the 12 months prior to launch.
///
/// Why store this instead of computing on-demand:
///  - The /home BiggestMovers card needs (today - 7d) as a baseline;
///    computing that from raw claims on every render is wasteful.
///  - The /politician/[id] timeline chart needs 26-52 data points per
///    politician — pre-baking is much cheaper than recomputing 52
///    Wilson intervals per render.
///  - We can change window math without touching live code paths.
///
/// Window choice: 30 days is the default (matches the site's primary
/// stats window). Other window sizes can coexist as separate rows.
model CredibilitySnapshot {
  id               String     @id @default(cuid())
  politicianId     String
  politician       Politician @relation(fields: [politicianId], references: [id])
  asOf             DateTime   // end of the rolling window
  windowDays       Int        // 30 by default
  totalClaims      Int        // sample size in the window
  trueClaims       Int
  halfTrue         Int
  falseClaims      Int
  truthPercentage  Float      // raw % (weighted: (true + 0.5*half) / total * 100)
  credibilityScore Float      // Wilson 95% lower bound, 0-100
  createdAt        DateTime   @default(now())

  @@unique([politicianId, asOf, windowDays])
  @@index([asOf])
  @@index([politicianId, asOf])
}

/// Knesset activity snapshot for one MK. One row per Politician, refreshed
/// daily by scripts/ingest-knesset-activity.mts. The metrics are computed
/// over a rolling window (default 90 days) and used by the
/// `<KnessetActivityCard>` on /politician/[id] + the leaderboard's
/// attendance threshold filter.
///
/// Data sources:
///  - Knesset OData `ParliamentInfo.svc` for bills (`KNS_Bill` +
///    `KNS_BillInitiator`, fresh — last bill ~4 days old) and committee
///    memberships (`KNS_PersonToPosition`).
///  - Our own `Article` table for plenum participation (counting
///    distinct sessions where the MK spoke). Knesset's public vote
///    OData is 5+ years stale and unusable for this purpose.
model KnessetActivity {
  id                       String     @id @default(cuid())
  politicianId             String     @unique
  politician               Politician @relation(fields: [politicianId], references: [id])

  /// KNS_Person.PersonID — kept so re-queries don't have to redo
  /// the Hebrew-name → MK lookup every run.
  knsPersonId              Int

  /// Window the stats below cover. Stored explicitly so a future cron
  /// can recompute over a different window without ambiguity.
  windowStart              DateTime
  windowEnd                DateTime

  /// Active plenum participation — derived from our Article rows
  /// (source="כנסת · מליאה"). We count distinct plenum sessions in
  /// the window where the MK spoke. Stronger signal than passive
  /// attendance — silence in the room doesn't show here. Knesset's
  /// own vote-attendance OData is 5+ years stale so this is the
  /// best public signal available.
  plenumSessionsTotal      Int
  plenumSessionsSpoken     Int
  plenumParticipationPct   Float

  /// Bills the MK initiated or co-initiated whose PublicationDate
  /// falls in the window.
  billsSponsored           Int

  /// Snapshot of current committee / role positions. JSON array of
  /// `{ id: number, name: string }`. Not windowed.
  committeesMember         Json

  fetchedAt                DateTime   @default(now())

  @@index([politicianId])
}

model Claim {
  id             String   @id @default(cuid())
  politicianId   String
  politician     Politician @relation(fields: [politicianId], references: [id])
  quote          String
  verdict        String   // "true" | "half-true" | "false"
  summary        String?  // one-sentence TL;DR of the explanation
  explanation    String
  source         String   // where the politician said it (e.g. "Ynet")
  sourceUrl      String
  factSource     String?  // authoritative data source
  factSourceUrl  String?
  topic          String
  date           DateTime
  status         String   @default("published") // "draft" | "review" | "published"
  confidence     Float?   // AI confidence score 0-1
  editorApproved Boolean  @default(false) // passed second-pass AI verification
  verifiedAt     DateTime? // when the second-pass verifier ran
  verifierNotes  String?  // issues raised by the verifier (if not approved)
  /// Set when a previously-public claim is amended or removed.
  /// Drives the /corrections log. Free-text Hebrew reason like
  /// "הוסר: דיווח עיתונאי בגוף שלישי, לא אמירה של הפוליטיקאי".
  correctionNote String?
  /// When the correction happened. Null = no correction. Updated
  /// independently of `updatedAt` (which updates on every edit).
  correctedAt    DateTime?
  /// When this claim was auto-posted to the Telegram channel (@bduk_il).
  /// Null = not yet posted. Pre-existing claims were backfilled to "now"
  /// so enabling auto-posting didn't blast the backlog. See
  /// scripts/post-to-telegram.mts + scripts/telegram-backfill.mts.
  telegramPostedAt DateTime?
  /// Editor's review-queue decision: "dismiss" | "publish". Set when a human
  /// acts on a withheld claim in /admin/review. Distinguishes the editor's own
  /// approve/reject calls from system/sweep status changes — the labeled data
  /// scripts/suggest-rules.mts mines to propose new deterministic filter rules.
  humanDecision    String?
  humanDecisionAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reports        Report[]
  comments       Comment[]

  @@index([politicianId])
  @@index([date])
  @@index([verdict])
}

model Comment {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
  author    String   // free-text name; no auth yet
  body      String
  createdAt DateTime @default(now())

  @@index([claimId])
  @@index([createdAt])
}

model Report {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
  reason    String
  details   String?
  createdAt DateTime @default(now())

  @@index([claimId])
}

model Article {
  id            String   @id @default(cuid())
  title         String
  url           String   @unique
  source        String   // "ynet" | "n12" | "walla" | etc
  content       String?
  publishedAt   DateTime?
  fetchedAt     DateTime @default(now())
  processed     Boolean  @default(false)
  extractedData String?  // JSON: extracted quotes and claims

  @@index([source])
  @@index([processed])
}

/// Weekly AI-generated insight paragraph per canonical topic. Lives on
/// /topic/[slug] above the deterministic insights band (which stays
/// as a fallback when no weekly insight exists yet for that topic).
///
/// One body field per (slug, weekOf). Body is journalist-voice Hebrew
/// with {{P:id|name}} markers — same convention as the weekly digest.
/// Generated by scripts/generate-topic-insights.mts running alongside
/// the weekly-digest cron (Friday 03/04 UTC).
///
/// No admin approval gate (unlike Digest). The deterministic templates
/// remain the fallback, so a bad AI output just gets superseded by
/// next week's run — worst case is one week of so-so insights, not a
/// broken page.
model TopicInsight {
  id          String   @id @default(cuid())
  /// Canonical topic slug from src/lib/topics.ts NORMALIZATIONS.
  slug        String
  /// Anchor date — the Friday this insight was generated for.
  weekOf      DateTime
  /// Topic label at generation time (snapshot — if NORMALIZATIONS
  /// renames a label later, the historical insight still reads sensibly).
  label       String
  /// Journalist-voice Hebrew body. May span multiple paragraphs
  /// separated by blank lines. Rendered via <InsightBody>.
  body        String
  generatedAt DateTime @default(now())

  @@unique([slug, weekOf])
  @@index([slug, weekOf])
}

/// Weekly digest issue. Pipeline auto-generates a draft each Friday
/// via scripts/generate-weekly-digest.mts; admin reviews/edits at
/// /admin/digest and flips status to "published". Public reader sees
/// the latest published issue at /digest and individual issues at
/// /digest/[weekOf-YYYY-MM-DD].
///
/// `sections` is a JSON array of structured blocks (movers, top
/// false claim, most-debated topic, headline). Lets the generator
/// produce data-rich drafts and lets the public renderer style each
/// section consistently. The admin can edit blocks via a textarea
/// (advanced) or use the per-section fields once we build them.
model Digest {
  id          String   @id @default(cuid())
  /// Anchor date: the Friday of the week this digest covers. Used
  /// as the URL slug (YYYY-MM-DD).
  weekOf      DateTime @unique
  /// "draft" (generator wrote it, admin hasn't approved) |
  /// "published" (live at /digest and /digest/[date])
  status      String   @default("draft")
  title       String
  intro       String   // 1-2 sentence framing for the issue
  sections    Json     // [{ type, heading, body, items?, ... }]
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, weekOf])
}

/// One row per day. Written at the end of each daily cron run and
/// surfaced on the admin status page so we can spot regressions
/// (queue depth blowing up, approval rate dropping, no fresh claims
/// for N days). Day field is stored as a string in YYYY-MM-DD form
/// so we get one row per calendar day regardless of write time.
model DailySnapshot {
  id              String   @id @default(cuid())
  day             String   @unique   // "2026-05-23"
  totalClaims     Int
  publishedClaims Int
  editorApproved  Int
  queueDepth      Int
  totalArticles   Int
  lastClaimAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([day])
}
