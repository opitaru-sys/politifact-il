# בדוק production environment variables
# Copy each into Vercel Project Settings → Environment Variables.
# DO NOT commit a filled-in version of this file.

# --- Database (required) ---
# Neon Postgres connection string. Use the "Pooled" URL for the runtime, and
# set DIRECT_URL to the unpooled URL if you ever run migrations from Vercel.
DATABASE_URL=postgresql://<user>:<password>@<hostname>/<dbname>?sslmode=require

# --- AI (required) ---
# Google Gemini API key. Used by extraction + fact-check + verifier.
# Create one free at https://aistudio.google.com/apikey. Free tier covers
# 500 grounded (Google Search) requests/day — enough for the daily ingest
# pipeline. Migrated here from Anthropic for cost reasons; see BACKLOG.md.
GEMINI_API_KEY=...

# --- Admin (required) ---
# Long random secret to gate /admin/* routes. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace-with-a-strong-random-string

# --- Site URL (required) ---
# Used for OG image baseUrl, sitemap, robots.txt, share text fallbacks.
# Set to https://bduk.co.il (or whatever domain you're using).
NEXT_PUBLIC_SITE_URL=https://bduk.co.il

# --- Rate limiting (optional but recommended) ---
# Upstash Redis credentials for distributed rate limiting on /api/comment and
# /api/report. If missing, falls back to in-memory limiting (resets per
# serverless invocation, so essentially no protection in production).
# Free tier covers thousands of requests per day.
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Error monitoring (optional but recommended) ---
# Sentry DSN. Captures server, edge, and client errors. NEXT_PUBLIC_SENTRY_DSN
# is required for client-side capture (it gets embedded in the JS bundle).
SENTRY_DSN=https://...@....ingest.us.sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}

# --- For local development ---
# When using a Neon dev branch locally too, set DATABASE_URL above to that
# branch's connection string. Keep prod and dev DBs separate.

# --- One-time migration only ---
# Required only when running `npm run db:migrate` to copy SQLite → Postgres.
# After migration is done, this can be removed.
# DATABASE_URL_POSTGRES=${DATABASE_URL}
